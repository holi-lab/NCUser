[
    {
        "app_name": "attraction",
        "api_name": "attraction_retrieve",
        "method": "GET",
        "description": "Retrieves an attraction (college, night club, museum etc.) list from the database that matches the given input parameter conditions. Up to 7 results will be displayed, and the rest will be truncated and not shown.",
        "parameters": [
            {
                "name": "area",
                "type": "string",
                "required": false,
                "description": "Location of the attraction.",
                "default": null,
                "constraints": ["north","west","south","east","centre"]
            },
            {
                "name": "name",
                "type": "string",
                "required": false,
                "description": "Name of the attraction. Must be entered in lowercase.",
                "default": null,
                "constraints": []
            },
            {
                "name": "type",
                "type": "string",
                "required": false,
                "description": "Type of the attraction service. Must be entered in lowercase.",
                "default": null,
                "constraints": []
            }
        ],
        "response_schemas": {
            "success": {
                    "success":"bool",
                    "result":[
                        {
                            "address": "string",
                            "area": "string",
                            "entrance fee": "string",
                            "id": "string",
                            "location": ["float","float"],
                            "name": "string",
                            "openhours": "string",
                            "phone": "string",
                            "postcode": "string",
                            "pricerange": "string",
                            "type": "string"
                        }
                    ]
            },
            "failure": {
                "success":"bool",
                "result":{
                    "message":"string"
                }
            }
        }
    },
    {
        "app_name": "accommodation",
        "api_name": "accommodation_retrieve",
        "method": "GET",
        "description": "Retrieves an accommodation (hotel, guesthouse etc.) list from the database that matches the given input parameter conditions. Up to 7 results will be displayed, and the rest will be truncated and not shown.",
        "parameters": [
            {
                "name": "area",
                "type": "string",
                "required": false,
                "description": "Location of the accommodation.",
                "default": null,
                "constraints": ["north","west","south","east","centre"]
            },
            {
                "name": "internet",
                "type": "bool",
                "required": false,
                "description": "Whether the accommodation offers internet.",
                "default": null,
                "constraints": [true,false]
            },
            {
                "name": "name",
                "type": "string",
                "required": false,
                "description": "Name of the accommodation. Must be entered in lowercase.",
                "default": null,
                "constraints": []
            },
            {
                "name": "parking",
                "type": "bool",
                "required": false,
                "description": "Whether the accommodation offers parking service.",
                "default": null,
                "constraints": [true,false]
            },
            {
                "name": "pricerange",
                "type": "string",
                "required": false,
                "description": "Indicates the approximate price range of the accommodation.",
                "default": null,
                "constraints": ["cheap","moderate","expensive"]
            },
            {
                "name": "stars",
                "type": "int",
                "required": false,
                "description": "The accommodation's rating represented in stars.",
                "default": null,
                "constraints": [0,1,2,3,4,5]
            },
            {
                "name": "type",
                "type": "string",
                "required": false,
                "description": "Represents the category of the accommodation.",
                "default": null,
                "constraints": ["bed and breakfast","guesthouse","hotel"]
            }
        ],
        "response_schemas": {
            "success": {
                    "success":"bool",
                    "result":[
                        {
                            "address": "string",
                            "area": "string",
                            "internet": "string",
                            "parking": "string",
                            "id": "string",
                            "location": ["float","float"],
                            "name": "string",
                            "phone": "string",
                            "postcode": "string",
                            "price": {
                                "double": "string",
                                "family": "string",
                                "single": "string"
                            },
                            "pricerange": "string",
                            "stars": "string",
                            "takesbookings": "string",
                            "type": "string"
                        }
                    ]
            },
            "failure": {
                "success":"bool",
                "result":{
                    "message":"string"
                }
            }
        }
    },
    {
        "app_name": "accommodation",
        "api_name": "accommodation_book",
        "method": "POST",
        "description": "Book the specific accommodation (hotel, guesthouse etc.) with the given input parameter options.",
        "parameters": [
            {
                "name": "id",
                "type": "int",
                "required": true,
                "description": "Unique id of the specific accommodation.",
                "default": null,
                "constraints": []
            },
            {
                "name": "day",
                "type": "str",
                "required": true,
                "description": "The day of the week for the check-in date.",
                "default": null,
                "constraints": ["sunday","monday","tuesday","wednesday","thursday","friday","saturday","sunday"]
            },
            {
                "name": "stay",
                "type": "int",
                "required": true,
                "description": "The number of days to stay at the accommodation.",
                "default": null,
                "constraints": []
            },
            {
                "name": "people",
                "type": "int",
                "required": true,
                "description": "The number of people to stay at the accommodation.",
                "default": null,
                "constraints": []
            }
        ],
        "response_schemas": {
            "success": {
                    "success":"bool",
                    "result":{
                        "message":"string"
                    }
            },
            "failure": {
                "success":"bool",
                "result":{
                    "message":"string"
                }
            }
        }
    },
