                "default": null,
                "constraints": "The time must be entered as a string in the hh:mm format, from 00:00 to 23:59."
            },
            {
                "name": "departure",
                "type": "str",
                "required": true,
                "description": "Departure location of the taxi. It's a name, not an Id. Must be entered in lowercase.",
